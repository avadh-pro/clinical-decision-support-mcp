# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Override Claude model (default: claude-sonnet-4-6-20250514)
# CLAUDE_MODEL=claude-sonnet-4-6-20250514

# Optional: Override port (default: 5000)
# PORT=3000

# Optional: Environment (dev/prod/local)
# PO_ENV=local
